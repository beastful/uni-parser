					                            visible: false,
					                            labels: { format: "" }
					                        },
					                        tooltip: { visible: true, template: "#= categoryAxis.categories #"},
					                        points:  { visible: true }
					                    });
                }
          function createChart_DOP(obj, N, count, median, values, pzk, type) {
                    var categs = [];
                    //if(N==7) alert(Math.max(Math.ceil(Math.max.apply(Math, values)),1.4));

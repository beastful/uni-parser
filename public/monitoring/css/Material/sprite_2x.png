<script>

$(function() {
  $(window).scroll(function(){
    if ($(window).scrollTop()>0)
      $('#to_begin').fadeIn(300);
    else 
	  $('#to_begin').fadeOut(300);
  });
  
 $('#to_begin').click(function(){
    $(window).scrollTop(0);
  }); 

});
</script>


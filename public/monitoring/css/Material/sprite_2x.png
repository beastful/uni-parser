<style>
#newsblock p:hover { color:#233; } 
#navmw a {
  text-decoration:none;	color:#888;
}
#navmw a:hover {
  text-decoration:underline;
}
.ent_b {
  
  user-select: none;
  outline: none;
  border: 1px solid rgba(0,0,0,.15);
  border-radius: 4px;
  background: #DCE6EA linear-gradient(#f4f4f4, #f1f1f1);
  transition: all .218s ease 0s;
  cursor:pointer;

}
.ent_b:hover {
  background: #EFF3F4 linear-gradient(#f4f4f4, #f1f1f1);
  box-shadow: 0 1px 2px rgba(0,0,0,.1);
}
.ent_b:active {
  background: rgb(238,238,238) linear-gradient(rgb(238,238,238), rgb(224,224,224));
  box-shadow: 0 1px 2px rgba(0,0,0,.1) inset;
}
.wlink {
	min-height:20px;margin:15px 0px;padding:5px 20px 5px 35px;font:normal 400 15px/16px Calibri;color:#333;
	background-position: left 10px top 5px;
		background-repeat:no-repeat;text-shadow:none;
transition-delay: 0s;
transition-duration: 0.2s;
transition-property: all;
transition-timing-function: ease;
}
.wlink:hover {background-color:rgba(0,0,0,0.05);}
.send-asc {
	background-attachment: scroll;
background-clip: border-box;
background-color: #22917B;
border-radius: 5px;
box-sizing: border-box;
color: rgb(255, 255, 255);
display: inline-block;
font-family: "Fira Sans",  sans-serif;
font-size: 14px;
font-weight: 600;
width:180px;
text-align:center;
line-height: 24px;
margin:10px;
margin-top: 24px;
padding-bottom: 7px;
padding-left: 16px;
padding-right: 16px;
padding-top: 5px;
text-shadow:none;
text-decoration: rgb(255, 255, 255);
text-decoration-color: rgb(255, 255, 255);
text-decoration-line: none;
text-decoration-style: solid;
text-decoration-thickness: auto;
transition-delay: 0s;
transition-duration: 0.5s;
transition-property: all;
transition-timing-function: ease;

}
.send-asc:hover {
	
background-color: #27827B;
}

 .navi_header p {font-family: Calibri;
  padding:0px 15px;color:#333;


</style>
<script>
$(document).mouseup(function (e) {
    var container = $("#auth");
    if (container.has(e.target).length === 0){
        container.hide();
    }
});
</script>

